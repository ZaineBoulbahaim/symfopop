{# Vista de login #}
{% extends 'base.html.twig' %}
{% block title %}Iniciar sessió{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="text-center mb-4">
                <i class="bi bi-lock-fill display-4" style="color: var(--primary)"></i>
                <h2 class="fw-bold mt-2">Iniciar sessió</h2>
                <p class="text-muted">Accedeix al teu compte de SymfoPop</p>
            </div>

            <div class="card shadow-sm border-0 p-4">
                {# Mostrem error d'autenticació si n'hi ha #}
                {% if error %}
                    <div class="alert alert-danger">
                        <i class="bi bi-x-circle me-2"></i>{{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post">
                    {# Camp email #}
                    <div class="mb-3">
                        <label class="form-label fw-bold">Correu electrònic</label>
                        <input type="email" name="email" class="form-control"
                               value="{{ last_username }}" required autofocus
                               placeholder="correu@exemple.com">
                    </div>

                    {# Camp contrasenya #}
                    <div class="mb-4">
                        <label class="form-label fw-bold">Contrasenya</label>
                        <input type="password" name="password" class="form-control"
                               required placeholder="La teva contrasenya">
                    </div>

                    {# Token CSRF per seguretat #}
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button type="submit" class="btn btn-primary w-100 mb-3">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar sessió
                    </button>

                    {# Enllaç al registre #}
                    <p class="text-center text-muted mb-0">
                        No tens compte?
                        <a href="{{ path('app_register') }}" style="color: var(--primary)">Registra't aquí</a>
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}