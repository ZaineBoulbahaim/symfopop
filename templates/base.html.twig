{# Layout base del qual hereten totes les vistes #}
<!DOCTYPE html>
<html lang="ca">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {# Títol dinàmic per cada pàgina #}
    <title>{% block title %}SymfoPop{% endblock %} | Mercat de Segona Mà</title>

    {# Bootstrap 5 i icones via CDN #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    {# CSS personalitzat en fitxer separat #}
    <link href="{{ asset('css/styles.css') }}" rel="stylesheet">

    {% block stylesheets %}{% endblock %}
</head>
<body>

{# ===== NAVBAR ===== #}
<nav class="navbar navbar-expand-lg sticky-top">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">
            <i class="bi bi-shop me-1" style="color: var(--primary)"></i>
            <span>SymfoPop</span>
        </a>

        {# Botó hamburguesa per mòbil #}
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_product_index') }}">
                        <i class="bi bi-grid me-1"></i>Productes
                    </a>
                </li>
            </ul>

            <ul class="navbar-nav">
                {# Menú diferent segons si l'usuari està autenticat #}
                {% if app.user %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_my_products') }}">
                            <i class="bi bi-box-seam me-1"></i>Els meus productes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-primary text-white px-3 me-2" href="{{ path('app_product_new') }}">
                            <i class="bi bi-plus-circle me-1"></i>Nou producte
                        </a>
                    </li>
                    {# Dropdown amb el nom de l'usuari #}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i>{{ app.user.name }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="{{ path('app_profile_edit') }}">
                                    <i class="bi bi-pencil me-2"></i>Editar perfil
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                {# Logout via POST amb token CSRF #}
                                <form action="{{ path('app_logout') }}" method="post">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Tancar sessió
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                {% else %}
                    {# Usuari no autenticat: Login i Registre #}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar sessió
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-primary text-white px-3" href="{{ path('app_register') }}">
                            <i class="bi bi-person-plus me-1"></i>Registrar-se
                        </a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

{# Missatges flash reutilitzables #}
<div class="container mt-3">
    {% include '_partials/_flash_messages.html.twig' %}
</div>

{# Bloc principal: cada pàgina sobreescriu aquest contingut #}
{% block body %}{% endblock %}

{# Footer #}
<footer class="mt-5 py-4">
    <div class="container text-center text-muted">
        <p class="mb-0">
            <i class="bi bi-shop me-1" style="color: var(--primary)"></i>
            <strong style="color: var(--primary)">SymfoPop</strong> · Mercat de Segona Mà · 2024
        </p>
    </div>
</footer>

{# Bootstrap JS #}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>