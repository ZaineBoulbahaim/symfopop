{# Vista detall d'un producte #}
{% extends 'base.html.twig' %}
{% block title %}{{ product.title }}{% endblock %}

{% block body %}
<div class="container py-5">
    <a href="{{ path('app_product_index') }}" class="btn btn-outline-secondary mb-4">
        <i class="bi bi-arrow-left me-2"></i>Tornar al llistat
    </a>

    <div class="row g-5">
        {# Imatge gran #}
        <div class="col-md-6">
            <img src="{{ product.image is not empty ? product.image : 'https://picsum.photos/seed/' ~ product.id ~ '/1200/800' }}""
                 class="img-fluid rounded shadow" alt="{{ product.title }}">
        </div>

        <div class="col-md-6">
            <h1 class="fw-bold mb-3">{{ product.title }}</h1>
            <div class="mb-4">
                <span class="price-badge fs-4">{{ product.price|number_format(2, ',', '.') }} €</span>
            </div>

            {# Descripció completa #}
            <div class="mb-4">
                <h5 class="fw-bold text-muted">Descripció</h5>
                <p class="lead">{{ product.description }}</p>
            </div>

            {# Info autor i data #}
            <div class="card bg-light border-0 p-3 mb-4">
                <div class="row">
                    <div class="col-6">
                        <small class="text-muted d-block">Publicat per</small>
                        <strong><i class="bi bi-person me-1"></i>{{ product.owner.name }}</strong>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Data de publicació</small>
                        <strong><i class="bi bi-calendar me-1"></i>{{ product.createdAt|date('d/m/Y') }}</strong>
                    </div>
                </div>
            </div>

            {# Botons editar/esborrar: només visibles per al propietari #}
            {% if app.user and app.user == product.owner %}
                <div class="d-flex gap-3">
                    <a href="{{ path('app_product_edit', {id: product.id}) }}" class="btn btn-warning flex-fill">
                        <i class="bi bi-pencil me-2"></i>Editar producte
                    </a>
                    {# Esborrat amb confirmació i CSRF #}
                    <form action="{{ path('app_product_delete', {id: product.id}) }}" method="post" class="flex-fill"
                          onsubmit="return confirm('Segur que vols esborrar aquest producte?')">
                        <input type="hidden" name="_method" value="DELETE">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                        <button type="submit" class="btn btn-danger w-100">
                            <i class="bi bi-trash me-2"></i>Esborrar producte
                        </button>
                    </form>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}