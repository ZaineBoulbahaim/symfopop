{# Vista per editar un producte. Reutilitza el MATEIX _product_form.html.twig que new #}
{% extends 'base.html.twig' %}
{% block title %}Editar: {{ product.title }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="text-center mb-4">
                <i class="bi bi-pencil-square display-4" style="color: var(--primary)"></i>
                <h2 class="fw-bold mt-2">Editar producte</h2>
                <p class="text-muted">Modificant: "{{ product.title }}"</p>
            </div>
            <div class="card shadow-sm border-0 p-4">
                {# Mateix formulari que new, només canvia button_label i cancel_url #}
                {% include '_partials/_product_form.html.twig' with {
                    'form': form,
                    'button_label': 'Guardar canvis',
                    'cancel_url': path('app_product_show', {id: product.id})
                } %}
            </div>
        </div>
    </div>
</div>
{% endblock %}